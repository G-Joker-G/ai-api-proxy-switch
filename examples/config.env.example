# AI API Proxy Switch Skill 配置文件示例
# 将此文件保存为 ~/.hermes/ai-api-proxy-config.env
# 使用方式: source ~/.hermes/ai-api-proxy-config.env

# ====================
# 必需配置
# ====================

# AI API Proxy API Key
# 从 https://api.clawsocket.com 获取
export OPENROUTER_API_KEY='cla_xxxxxxxxxxxxxxxxxxxxxxxx'

# API 端点 URL
export OPENROUTER_BASE_URL='https://api.clawsocket.com/v1'

# ====================
# 可选配置
# ====================

# 默认模型 (如果不指定 --model 参数)
export OPENROUTER_MODEL='gpt-5.2'

# API 调用超时时间 (秒)
export OPENROUTER_TIMEOUT=60

# 最大生成 token 数
export OPENROUTER_MAX_TOKENS=4096

# 生成温度 (0.0-2.0)
# 较低值更确定，较高值更有创意
export OPENROUTER_TEMPERATURE=0.7

# 是否启用调试模式
# export HERMES_DEBUG=1
# export OPENROUTER_DEBUG=1

# ====================
# 代理配置 (如果需要)
# ====================

# HTTP/HTTPS 代理
# export HTTP_PROXY='http://proxy.example.com:8080'
# export HTTPS_PROXY='http://proxy.example.com:8080'

# SOCKS5 代理
# export ALL_PROXY='socks5://proxy.example.com:1080'

# 排除代理的地址
# export NO_PROXY='localhost,127.0.0.1,*.internal'

# ====================
# 自定义模型映射
# ====================

# 自定义模型别名
# 格式: export OPENROUTER_MODEL_MAPPING='{"alias": "provider/model"}'
# export OPENROUTER_MODEL_MAPPING='{"my-gpt": "openai/gpt-5.2", "my-claude": "anthropic/claude-sonnet-4-6"}'

# ====================
# 使用示例
# ====================

# 1. 加载配置
#   source ~/.hermes/ai-api-proxy-config.env

# 2. 使用默认模型
#   hermes chat --skills ai-api-proxy-switch --query "你的问题"

# 3. 指定模型
#   hermes chat --skills ai-api-proxy-switch --model claude-sonnet-4-6 --query "你的问题"

# 4. 使用自定义模型别名
#   hermes chat --skills ai-api-proxy-switch --model my-gpt --query "你的问题"

# ====================
# 环境变量验证
# ====================

echo "=== AI API Proxy 配置检查 ==="
echo "API Key: ${OPENROUTER_API_KEY:0:10}..."
echo "Base URL: $OPENROUTER_BASE_URL"
echo "默认模型: ${OPENROUTER_MODEL:-未设置}"
echo "超时时间: ${OPENROUTER_TIMEOUT}秒"
echo "最大 token: ${OPENROUTER_MAX_TOKENS}"
echo "温度: ${OPENROUTER_TEMPERATURE}"
echo "============================="